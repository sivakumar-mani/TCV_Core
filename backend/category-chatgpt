-- TS Logic
levels: any[] = [];

ngOnInit() {
  this.loadRoot();
}

loadRoot() {
  this.api.getByParent(null).subscribe(res => {
    this.levels[0] = res;
  });
}

onSelect(event: any, index: number) {
  const parentId = event.target.value;

  // remove next levels
  this.levels = this.levels.slice(0, index + 1);

  if (parentId) {
    this.api.getByParent(parentId).subscribe(res => {
      if (res.length > 0) {
        this.levels[index + 1] = res;
      }
    });
  }
}

